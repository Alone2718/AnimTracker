local function createEntry(scroll, id)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -10, 0, 35)
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    frame.Parent = scroll
    Instance.new("UICorner", frame)

    local idLabel = Instance.new("TextLabel")
    idLabel.Size = UDim2.new(0.7, 0, 1, 0)
    idLabel.Position = UDim2.new(0, 10, 0, 0)
    idLabel.Text = id:match("%d+") or id
    idLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
    idLabel.Font = Enum.Font.Code
    idLabel.TextSize = 14
    idLabel.BackgroundTransparency = 1
    idLabel.TextXAlignment = "Left"
    idLabel.Parent = frame

    local copy = Instance.new("TextButton")
    copy.Size = UDim2.new(0, 60, 0, 25)
    copy.Position = UDim2.new(1, -65, 0.5, -12)
    copy.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    copy.Text = "COPY"
    copy.TextColor3 = Color3.new(1,1,1)
    copy.Font = Enum.Font.Gotham
    copy.TextSize = 10
    copy.Parent = frame
    Instance.new("UICorner", copy)

    copy.MouseButton1Click:Connect(function()
        Clipboard(idLabel.Text)
        copy.Text = "DONE"
        task.wait(0.5)
        copy.Text = "COPY"
    end)
    scroll.CanvasPosition = Vector2.new(0, 99999)
end

local function setupPlayer(plr)
    if PlayerLogs[plr.UserId] then return end
    local scroll = Instance.new("ScrollingFrame")
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.Visible = false
    scroll.BackgroundTransparency = 1
    scroll.ScrollBarThickness = 4
    scroll.AutomaticCanvasSize = "Y"
    scroll.Parent = LogContainer
    Instance.new("UIListLayout", scroll).Padding = UDim.new(0, 5)
    
    PlayerLogs[plr.UserId] = scroll
    
    local function listen(char)
        local animator = char:WaitForChild("Humanoid"):WaitForChild("Animator")
        animator.AnimationPlayed:Connect(function(track)
            local n = track.Animation.Name:lower()
            local id = track.Animation.AnimationId
            -- Strict Movement Filter
            local filter = {"idle", "walk", "run", "fall", "jump", "climb", "swim", "move", "sit"}
            for _, word in pairs(filter) do if n:find(word) then return end end
            if id == "" or id == " " then return end
            
            createEntry(scroll, id)
        end)
    end
    if plr.Character then task.spawn(listen, plr.Character) end
    plr.CharacterAdded:Connect(listen)
end

local function updateList()
    for _, v in pairs(Sidebar:GetChildren()) do 
        if v:IsA("TextButton") and v ~= Refresh then v:Destroy() end 
    end
    for _, plr in pairs(Players:GetPlayers()) do
        setupPlayer(plr)
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1, -10, 0, 30)
        b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        b.Text = plr.Name
        b.TextColor3 = Color3.new(1,1,1)
        b.Font = Enum.Font.Gotham
        b.TextSize = 11
        b.Parent = Sidebar
        Instance.new("UICorner", b)
        
        b.MouseButton1Click:Connect(function()
            if CurrentLog then CurrentLog.Visible = false end
            CurrentLog = PlayerLogs[plr.UserId]
            CurrentLog.Visible = true
            Title.Text = "LOGGING: " .. plr.Name:upper()
        end)
    end
end

Refresh.MouseButton1Click:Connect(updateList)
updateList()
