-- Function: Create Log Entry with Copy Button
local function logAnim(name, id)
    local entryFrame = Instance.new("Frame")
    entryFrame.Size = UDim2.new(1, 0, 0, 25)
    entryFrame.BackgroundTransparency = 1
    entryFrame.Parent = LogScroll

    local copy = Instance.new("TextButton")
    copy.Size = UDim2.new(0, 45, 0, 20)
    copy.Position = UDim2.new(0, 0, 0, 2)
    copy.Text = "COPY"
    copy.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
    copy.TextColor3 = Color3.new(1,1,1)
    copy.Font = Enum.Font.Gotham
    copy.TextSize = 10
    copy.Parent = entryFrame
    Instance.new("UICorner", copy).CornerRadius = UDim.new(0, 4)

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -55, 1, 0)
    label.Position = UDim2.new(0, 50, 0, 0)
    label.Text = string.format("[%s] ID: %s", name, id)
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 12
    label.Parent = entryFrame

    copy.MouseButton1Click:Connect(function()
        local rawId = id:match("%d+")
        Clipboard(rawId)
        copy.Text = "DONE!"
        task.wait(1)
        copy.Text = "COPY"
    end)
end

-- Watching Logic
local function watchPlayer(plr)
    for _, v in pairs(Connections) do v:Disconnect() end
    TargetPlayer = plr
    logAnim("SYSTEM", "Watching " .. plr.Name)
    
    local function connectTrack(char)
        local hum = char:WaitForChild("Humanoid", 5)
        local animator = hum and hum:WaitForChild("Animator", 5)
        if animator then
            Connections["Anim"] = animator.AnimationPlayed:Connect(function(track)
                local n = track.Animation.Name:lower()
                local moveAnims = {"idle", "walk", "run", "swim", "jump", "fall", "climb"}
                local isMove = false
                for _, word in pairs(moveAnims) do if n:find(word) then isMove = true break end end
                
                if not isMove then
                    logAnim(track.Animation.Name, track.Animation.AnimationId)
                end
            end)
        end
    end
    
    if plr.Character then connectTrack(plr.Character) end
    Connections["Char"] = plr.CharacterAdded:Connect(connectTrack)
end

-- Refresh List
local function refreshPlayers()
    for _, v in pairs(PlayerList:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, plr in pairs(Players:GetPlayers()) do
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1, -4, 0, 28)
        b.Text = plr.Name
        b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        b.TextColor3 = Color3.new(1, 1, 1)
        b.Font = Enum.Font.Gotham
        b.TextSize = 12
        b.Parent = PlayerList
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
        b.MouseButton1Click:Connect(function() watchPlayer(plr) end)
    end
end

