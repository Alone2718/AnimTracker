PLayLayout.Parent = PlayerList

-- Logic Functions
local function logAnim(name, id)
    local entry = Instance.new("TextLabel")
    entry.Size = UDim2.new(1, 0, 0, 20)
    entry.Text = string.format("[%s] %s", name, id)
    entry.TextColor3 = Color3.fromRGB(200, 200, 200)
    entry.BackgroundTransparency = 1
    entry.TextXAlignment = Enum.TextXAlignment.Left
    entry.Parent = LogScroll
    LogScroll.CanvasPosition = Vector2.new(0, LogScroll.AbsoluteCanvasSize.Y)
end

local function watchPlayer(plr)
    for _, v in pairs(Connections) do v:Disconnect() end
    TargetPlayer = plr
    logAnim("SYSTEM", "Watching: " .. plr.Name)
    
    local function connectTrack(char)
        local animator = char:WaitForChild("Humanoid"):WaitForChild("Animator")
        Connections["Anim"] = animator.AnimationPlayed:Connect(function(track)
            local name = track.Animation.Name:lower()
            -- Filtering movement junk
            if not name:find("idle") and not name:find("walk") and not name:find("run") and not name:find("swim") then
                logAnim(track.Animation.Name, track.Animation.AnimationId)
            end
        end)
    end
    
    if plr.Character then connectTrack(plr.Character) end
    Connections["Char"] = plr.CharacterAdded:Connect(connectTrack)
end

local function refreshPlayers()
    for _, v in pairs(PlayerList:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, plr in pairs(Players:GetPlayers()) do
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1, 0, 0, 25)
        b.Text = plr.Name
        b.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        b.TextColor3 = Color3.new(1, 1, 1)
        b.MouseButton1Click:Connect(function() watchPlayer(plr) end)
        b.Parent = PlayerList
    end
end

-- UI Controls
MinimizeBtn.MouseButton1Click:Connect(function()
    IsMinimized = not IsMinimized
    LogScroll.Visible = not IsMinimized
    PlayerList.Visible = not IsMinimized
    MainFrame.Size = IsMinimized and UDim2.new(0, 400, 0, 30) or UDim2.new(0, 400, 0, 300)
end)

CloseBtn.MouseButton1Click:Connect(function()
    for _, v in pairs(Connections) do v:Disconnect() end
    ScreenGui:Destroy()
end)

RefreshBtn.MouseButton1Click:Connect(refreshPlayers)

refreshPlayers()
