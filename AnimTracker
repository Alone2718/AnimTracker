ctrlBtn("↺", UDim2.new(1, -60, 0, 5), Color3.fromRGB(50, 120, 50), function() refresh() end)

-- Storage
local PlayerLogs = {} -- Stores the ScrollingFrames for each player
local CurrentVisibleLog = nil

local function createLogEntry(parent, id)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -10, 0, 30)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.Parent = parent
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 4)

    local idText = Instance.new("TextLabel")
    idText.Size = UDim2.new(1, -70, 1, 0)
    idText.Position = UDim2.new(0, 10, 0, 0)
    idText.Text = id:match("%d+") or id
    idText.TextColor3 = Color3.fromRGB(0, 255, 150)
    idText.Font = Enum.Font.Code
    idText.TextSize = 14
    idText.BackgroundTransparency = 1
    idText.TextXAlignment = "Left"
    idText.Parent = frame

    local copy = Instance.new("TextButton")
    copy.Size = UDim2.new(0, 50, 0, 20)
    copy.Position = UDim2.new(1, -55, 0, 5)
    copy.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    copy.Text = "COPY"
    copy.Font = Enum.Font.Gotham
    copy.TextSize = 10
    copy.TextColor3 = Color3.new(1,1,1)
    copy.Parent = frame
    Instance.new("UICorner", copy).CornerRadius = UDim.new(0, 4)

    copy.MouseButton1Click:Connect(function()
        Clipboard(idText.Text)
        copy.Text = "OK!"
        task.wait(0.5)
        copy.Text = "COPY"
    end)
    
    -- Auto-scroll to bottom
    parent.CanvasPosition = Vector2.new(0, parent.AbsoluteCanvasSize.Y)
end

local function switchTab(plr)
    if CurrentVisibleLog then CurrentVisibleLog.Visible = false end
    
    if not PlayerLogs[plr.UserId] then
        local scroll = Instance.new("ScrollingFrame")
        scroll.Size = UDim2.new(1, 0, 1, 0)
        scroll.BackgroundTransparency = 1
        scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
        scroll.AutomaticCanvasSize = "Y"
        scroll.ScrollBarThickness = 4
        scroll.Visible = false
        scroll.Parent = Container
        
        local layout = Instance.new("UIListLayout")
        layout.Parent = scroll
        layout.Padding = UDim.new(0, 5)
        
        PlayerLogs[plr.UserId] = scroll
        
        -- Start Watching
        local function hook(char)
            local animator = char:WaitForChild("Humanoid"):WaitForChild("Animator")
            animator.AnimationPlayed:Connect(function(track)
                local n = track.Animation.Name:lower()
                local move = {"idle", "walk", "run", "swim", "jump", "fall", "climb"}
                for _, v in pairs(move) do if n:find(v) then return end end
                createLogEntry(scroll, track.Animation.AnimationId)
            end)
        end
        if plr.Character then task.spawn(hook, plr.Character) end
        plr.CharacterAdded:Connect(hook)
    end
    
    CurrentVisibleLog = PlayerLogs[plr.UserId]
    CurrentVisibleLog.Visible = true
    Title.Text = "WATCHING: " .. plr.Name:upper()
end

function refresh()
    for _, v in pairs(Sidebar:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, plr in pairs(Players:GetPlayers()) do
        local b = Instance.new("TextButton")
        b.Size = UDim2.new(1, -10, 0, 30)
        b.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        b.Text = plr.Name
        b.TextColor3 = Color3.new(0.8, 0.8, 0.8)
        b.Font = Enum.Font.Gotham
        b.TextSize = 12
        b.Parent = Sidebar
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
        
        b.MouseButton1Click:Connect(function()
            for _, other in pairs(Sidebar:GetChildren()) do 
                if other:IsA("TextButton") then other.BackgroundColor3 = Color3.fromRGB(35, 35, 35) end 
            end
            b.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
            switchTab(plr)
        end)
    end
end

refresh()
